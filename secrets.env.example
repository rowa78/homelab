# Domain (wird von Stacks als Label-Variable genutzt)
DOMAIN=example.com
DISKSTATION_DOMAIN=ds.example.com

# E-Mail für Let's Encrypt ACME
TRAEFIK_ACME_EMAIL=mail@example.com

# Pfad zum zentralen Datenverzeichnis auf dem Server
DATA_DIR=/opt/homelab/data

# Webhook HMAC Secret (zufälliger String, min. 32 Zeichen)
# Generieren: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# SSH Deploy Key (base64-kodiert) für Verbindung zu Zielhosts
# Generieren: ssh-keygen -t ed25519 -C "homelab-deploy" -f ~/.ssh/homelab_deploy
# Kodieren:   base64 -w 0 ~/.ssh/homelab_deploy
# Public Key auf jedem Zielhost eintragen: ~/.ssh/authorized_keys
DEPLOY_SSH_KEY_B64=REPLACE_WITH_BASE64_ENCODED_PRIVATE_KEY

# Renovate GitHub Personal Access Token
# Berechtigungen: repo (read/write), workflow
RENOVATE_TOKEN=ghp_REPLACE_WITH_GITHUB_PAT

# GitHub Repository für Renovate (Format: user/repo)
RENOVATE_REPOSITORIES=REPLACE_WITH_GITHUB_USER/homelab
