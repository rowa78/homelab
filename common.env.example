# Geteilte Variablen für alle Stacks.
# Wird bei jedem Deployment zuerst entschlüsselt und mit stack-spezifischen Secrets gemergt:
#
#   sops -d /opt/homelab/common.enc.env > /opt/homelab/apps/<stack>/.env
#   sops -d /opt/homelab/apps/<stack>/secrets.enc.env >> /opt/homelab/apps/<stack>/.env
#
# Workflow zum Bearbeiten:
#   sops common.enc.env

DOMAIN=example.com
DATA_DIR=/opt/homelab/data
